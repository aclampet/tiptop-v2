# ============================================================
# TipTop.review v2.0 — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values

# ============================================================
# SUPABASE (Required)
# ============================================================
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# APPLICATION
# ============================================================
# Your production domain (no trailing slash)
NEXT_PUBLIC_APP_URL=https://tiptop.review

# ============================================================
# EMAIL (Optional - for notifications)
# ============================================================
# Get API key from: https://resend.com/api-keys
# Leave blank to disable email notifications

RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=notifications@tiptop.review

# Optional: Admin notification email
ADMIN_EMAIL=admin@tiptop.review

# ============================================================
# RATE LIMITING (Optional)
# ============================================================
# Upstash Redis (preferred) - if set, rate limits use Redis; else Supabase table fallback
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Optional overrides (defaults shown):
# RATE_LIMIT_REVIEW_MAX=5
# RATE_LIMIT_REVIEW_WINDOW_SECONDS=60
# RATE_LIMIT_QR_SCANS_MAX=20
# RATE_LIMIT_QR_SCANS_WINDOW_SECONDS=60
# RATE_LIMIT_VERIFY_EMAIL_MAX=10
# RATE_LIMIT_VERIFY_EMAIL_WINDOW_SECONDS=60
# RATE_LIMIT_HR_APPROVE_MAX=10
# RATE_LIMIT_HR_APPROVE_WINDOW_SECONDS=60
# RATE_LIMIT_CLAIM_MAX=5
# RATE_LIMIT_CLAIM_WINDOW_SECONDS=600
# RATE_LIMIT_MEMBERS_INVITE_MAX=20
# RATE_LIMIT_MEMBERS_INVITE_WINDOW_SECONDS=86400

# ============================================================
# REVIEW SUBMISSION (Optional)
# ============================================================
# Require CAPTCHA for review submissions (future use; not implemented yet)
# REVIEW_REQUIRE_CAPTCHA=false

# Max request body size for review submission (bytes, default 32768)
# REVIEW_MAX_BODY_BYTES=32768

# ============================================================
# NOTES
# ============================================================
# - Supabase keys are REQUIRED for the app to function
# - NEXT_PUBLIC_APP_URL should match your Vercel deployment URL
# - Resend is optional but recommended for production
# - Make sure to add your Vercel domain to Supabase URL Configuration:
#   Supabase Dashboard → Authentication → URL Configuration
#   Add: https://your-domain.vercel.app/*, https://tiptop.review/*
