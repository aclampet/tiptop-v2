# ============================================================
# TipTop.review v2.0 — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values

# ============================================================
# SUPABASE (Required)
# ============================================================
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# APPLICATION
# ============================================================
# Your production domain (no trailing slash)
NEXT_PUBLIC_APP_URL=https://tiptop.review

# ============================================================
# EMAIL (Optional - for notifications)
# ============================================================
# Get API key from: https://resend.com/api-keys
# Leave blank to disable email notifications

RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=notifications@tiptop.review

# Optional: Admin notification email
ADMIN_EMAIL=admin@tiptop.review

# ============================================================
# NOTES
# ============================================================
# - Supabase keys are REQUIRED for the app to function
# - NEXT_PUBLIC_APP_URL should match your Vercel deployment URL
# - Resend is optional but recommended for production
# - Make sure to add your Vercel domain to Supabase URL Configuration:
#   Supabase Dashboard → Authentication → URL Configuration
#   Add: https://your-domain.vercel.app/*, https://tiptop.review/*
